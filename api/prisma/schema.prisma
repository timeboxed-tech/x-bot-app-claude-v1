generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name         String
  passwordHash String   @default("")
  isAdmin      Boolean  @default(false)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())

  bots      Bot[]
  botShares BotShare[]
}

model Bot {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid
  xAccessToken        String   @default("")
  xAccessSecret       String   @default("")
  xAccountHandle      String   @default("")
  platform            String   @default("x")
  prompt              String   @db.Text
  postMode            String   @default("manual")
  postsPerDay         Int      @default(3)
  minIntervalHours    Int      @default(2)
  preferredHoursStart Int      @default(0)
  preferredHoursEnd   Int      @default(24)
  knowledgeSource      String   @default("ai")
  judgeKnowledgeSource String   @default("ai")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  posts     Post[]
  jobs      Job[]
  shares    BotShare[]
  tips      BotTip[]
  behaviours BotBehaviour[]
  botJudges BotJudge[]
}

model BotShare {
  id        String   @id @default(uuid()) @db.Uuid
  botId     String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  bot  Bot  @relation(fields: [botId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([botId, userId])
}

model Post {
  id          String    @id @default(uuid()) @db.Uuid
  botId       String    @db.Uuid
  jobId       String?   @db.Uuid
  content     String    @db.Text
  status      String    @default("draft")
  rating      Int?
  flagged     Boolean   @default(false)
  flagReasons String[]
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  behaviourPrompt  String?  @db.Text
  behaviourTitle   String?
  generationPrompt String?  @db.Text
  metadata         String?  @db.Text

  bot         Bot              @relation(fields: [botId], references: [id])
  job         Job?             @relation(fields: [jobId], references: [id])
  reviews     PostReview[]
  evaluations PostEvaluation[]

  @@index([botId, status])
  @@index([status, scheduledAt])
}

model BotTip {
  id        String   @id @default(uuid()) @db.Uuid
  botId     String   @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now())

  bot Bot @relation(fields: [botId], references: [id])
}

model BotBehaviour {
  id        String   @id @default(uuid()) @db.Uuid
  botId     String   @db.Uuid
  title     String   @default("")
  content         String   @db.Text
  knowledgeSource String   @default("default")
  outcome         String   @default("write_post")
  queryPrompt     String?  @db.Text
  weight          Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  bot Bot @relation(fields: [botId], references: [id])

  @@map("BotBehaviour")
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @default("draft")
  botId       String?   @db.Uuid
  status      String    @default("pending")
  lockToken   String?   @db.Uuid
  lockedAt    DateTime?
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  error       String?   @db.Text
  createdAt   DateTime  @default(now())

  bot   Bot?   @relation(fields: [botId], references: [id])
  posts Post[]

  @@index([type, status, scheduledAt])
  @@index([status, lockedAt])
}

model Judge {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  prompt     String    @db.Text
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  botJudges BotJudge[]
  reviews   PostReview[]
}

model BotJudge {
  id        String   @id @default(uuid()) @db.Uuid
  botId     String   @db.Uuid
  judgeId   String   @db.Uuid
  createdAt DateTime @default(now())

  bot   Bot   @relation(fields: [botId], references: [id])
  judge Judge @relation(fields: [judgeId], references: [id])

  @@unique([botId, judgeId])
}

model PostReview {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  judgeId   String   @db.Uuid
  rating    Int
  opinion   String   @db.Text
  createdAt DateTime @default(now())

  post  Post  @relation(fields: [postId], references: [id])
  judge Judge @relation(fields: [judgeId], references: [id])
}

model PostEvaluation {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  messages  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id])
}

model SystemPrompt {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  name      String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model JobConfig {
  id         String   @id @default(uuid()) @db.Uuid
  jobType    String   @unique
  intervalMs Int
  enabled    Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}
